    <title>{{ title or "Fragment Gallery" }}</title>
    <link rel="stylesheet" href="/css/style.css">
    <!-- Local HTMX reference: stable and fast -->
    <script src="/assets/js/htmx.min.js"></script>
</head>
<body>
