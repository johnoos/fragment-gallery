<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{ title or "Fragment Gallery" }}</title>
    <link rel="stylesheet" href="/css/base.css">
    <link rel="stylesheet" href="/css/desktop.css">
    <link rel="stylesheet" href="/css/mobile.css">
</head>
<body>
    {% include "partials/header.html" %}

    <div class="layout-wrapper">
            {% include "partials/sidebar.html" %}

            {# This is the ONLY place content enters the shell #}
            <main id="content-panel-container">
                {% block main %}{% endblock %}
            </main>   
    </div>
    
    <!-- Spinner overlay -->
    <div id="page-spinner" class="spinner-overlay" style="display: none;">
        <div class="spinner"></div>
    </div>

    {% include "partials/footer.html" %}

    <div id="menu-overlay"></div> 

<script type="module" src="/assets/js/controllerNavHandler.js"></script>
</body>
</html>